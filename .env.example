# ==============================================================
# PromptStudio - Environment Variables (template)
# ==============================================================
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it is git-ignored.
# ==============================================================

# ---- Auth (REQUIRED) ----
# Used to sign JWT session cookies. If unset, the app falls back to an
# insecure default and logs a warning — NEVER use the default in production.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=

# ---- Google Gemini (REQUIRED for default model) ----
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=

# ---- NVIDIA NIM (OPTIONAL — unlocks DeepSeek V3.2, Qwen 3.5, GLM 4.7, Kimi K2, GPT-OSS 120B) ----
# Get one at https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ---- NVIDIA image generation (OPTIONAL — unlocks in-app Flux + Stable Diffusion 3.5) ----
# These can be separate keys scoped to specific model endpoints, or reuse NVIDIA_API_KEY.
NVIDIA_API_KEY_FLUX=
NVIDIA_API_KEY_SD35=

# Override the Flux / Stable Diffusion endpoints if your account has access to
# different variants. Defaults: flux.1-schnell and stable-diffusion-3-5-large.
# Flux variants: flux.1-schnell (4 steps), flux.1-dev (30 steps), flux.1-pro.
# SD variants:   stable-diffusion-3-5-large, stable-diffusion-3-medium, sdxl-turbo.
# NVIDIA_FLUX_URL=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.1-dev
# NVIDIA_SD_URL=https://ai.api.nvidia.com/v1/genai/stabilityai/stable-diffusion-3-medium

# ---- Turso (libSQL) database — REQUIRED for production deployment ----
# Sign up at https://turso.tech, create a database, generate an auth token.
# For local dev, you can leave these blank to use a local SQLite file.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- Dev-only: LAN access ----
# Comma-separated list of origins allowed to hit the Turbopack dev server from
# another device on your network. Leave blank unless you actually need it.
# ALLOWED_DEV_ORIGINS=http://192.168.1.10:9080
