# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.genkit/*

# Secrets — never commit. Keep .env.example as the public template.
.env*
!.env.example

# firebase
firebase-debug.log
firestore-debug.log

# Local SQLite database (auto-created on first run)
data/

# Claude Code local state
.claude/

# Editor
.idea/
*.swp
